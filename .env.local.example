# -------------------------------------------------------
# Antigravity Dashboard — Environment Variables
# Copy this file to .env.local and fill in the values.
# NEVER commit .env.local to version control.
# -------------------------------------------------------

# 32-byte AES-256 key, hex-encoded (64 hex characters).
# Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=your_64_char_hex_key_here

# The base URL of this app (used for OAuth callback redirect URI).
# For local development, use the port in package.json "dev" script (39281).
NEXT_PUBLIC_APP_URL=http://localhost:39281

# Google OAuth credentials.
# These are the Google Cloud Code native-app OAuth credentials that the
# Antigravity IDE itself uses internally (public, installed-app client).
# You can find them in the Antigravity IDE source or use your own GCP project.
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
